Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /torneo/

    # API REST v1 — pasar el header Authorization a PHP
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^api/v1(/.*)?$ api/index.php [L,QSA]

    # Rutas limpias
    RewriteRule ^admin/acta/([0-9]+)/?$ admin/acta/index.php?id=$1 [L,QSA]
    RewriteRule ^pantalla-live/([0-9]+)/?$ pantalla-live/index.php?id=$1 [L,QSA]
    RewriteRule ^public/partido/([0-9]+)/?$ public/partido.php?id=$1 [L,QSA]
</IfModule>

<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
